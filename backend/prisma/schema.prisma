generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MEMBER
  ADMIN
  SUPER_ADMIN
}

enum Role {
  ADMIN
  MEMBER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REOPENED
  CLOSED
}

enum Severity {
  CRITICAL
  MAJOR
  MINOR
  TRIVIAL
}

enum PhaseStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      UserRole  @default(MEMBER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  projectMembers ProjectMember[]
  assignedTasks  Task[]          @relation("TaskAssignee")
  createdTasks   Task[]          @relation("TaskCreator")
  uploadedFiles  TaskFile[]
  ownedProjects  Project[]
  activityLogs   ActivityLog[]
  comments       TaskComment[]
  notifications  Notification[]
  timeEntries    TimeEntry[]
  watchedTasks   TaskWatcher[]
  reportedIssues  Issue[] @relation("IssueReporter")
  assignedIssues  Issue[] @relation("IssueAssignee")
  uploadedProjectDocuments ProjectDocument[]
  createdLinks ResourceLink[]
  chatMessages  ChatMessage[]
  conversationsAs1 Conversation[] @relation("ConvParticipant1")
  conversationsAs2 Conversation[] @relation("ConvParticipant2")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy String
  creator   User            @relation(fields: [createdBy], references: [id])
  labels    Label[]
  members   ProjectMember[]
  tasks     Task[]
  phases    Phase[]
  issues    Issue[]
  documents ProjectDocument[]
  links     ResourceLink[]
  chatMessages ChatMessage[]
}

model ProjectMember {
  id        String   @id @default(cuid())
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdById String
  createdBy  User   @relation("TaskCreator", fields: [createdById], references: [id])

  files     TaskFile[]
  comments  TaskComment[]
  subtasks  SubTask[]
  labels    TaskLabel[]
  notifications Notification[]
  dependents  TaskDependency[] @relation("TaskDependent")
  dependsOn   TaskDependency[] @relation("TaskDependsOn")
  timeEntries   TimeEntry[]
  watchers      TaskWatcher[]
  links         ResourceLink[]
  chatMessages  ChatMessage[]
}

model TaskFile {
  id        String   @id @default(cuid())
  name      String
  size      Int
  type      String
  path      String
  createdAt DateTime @default(now())

  taskId       String
  task         Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([createdAt])
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
  user   User @relation(fields: [userId], references: [id])
}

model SubTask {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId     String
  task       Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Label {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     TaskLabel[]

  @@unique([name, projectId])
}

model TaskLabel {
  taskId  String
  task    Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  labelId String
  label   Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
  taskId String?
  task   Task?  @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([createdAt])
}

model TaskDependency {
  id          String @id @default(cuid())
  dependentId String
  dependsOnId String

  dependent Task @relation("TaskDependent", fields: [dependentId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("TaskDependsOn", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([dependentId, dependsOnId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  hours       Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
  user   User @relation(fields: [userId], references: [id])
}

model TaskWatcher {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  taskId String
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String
  user      User @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
}

model Phase {
  id          String      @id @default(cuid())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?
  status      PhaseStatus @default(PLANNED)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Issue {
  id          String      @id @default(cuid())
  title       String
  description String?
  status      IssueStatus @default(OPEN)
  priority    Priority    @default(MEDIUM)
  severity    Severity    @default(MAJOR)
  dueDate     DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId String?
  assignee   User?   @relation("IssueAssignee", fields: [assigneeId], references: [id])
  reporterId String
  reporter   User   @relation("IssueReporter", fields: [reporterId], references: [id])
}

model ProjectDocument {
  id        String   @id @default(cuid())
  name      String
  size      Int
  type      String
  path      String
  createdAt DateTime @default(now())

  projectId    String
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User    @relation(fields: [uploadedById], references: [id])
}

model ResourceLink {
  id          String   @id @default(cuid())
  url         String
  title       String
  description String?
  createdAt   DateTime @default(now())

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
}

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participant1Id String
  participant1   User   @relation("ConvParticipant1", fields: [participant1Id], references: [id])
  participant2Id String
  participant2   User   @relation("ConvParticipant2", fields: [participant2Id], references: [id])
  messages       ChatMessage[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  projectId String?
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@index([projectId, createdAt])
  @@index([taskId, createdAt])
  @@index([conversationId, createdAt])
  @@index([createdAt])
}
